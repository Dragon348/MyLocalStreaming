{
    auto_https off
}

:80 {
    root * /workspace/web/dist

    handle /health* {
        respond "OK" 200
    }

    handle /api/v1/* {
        reverse_proxy backend:8000
    }

    handle /docs {
        reverse_proxy backend:8000
    }

    handle /openapi.json {
        reverse_proxy backend:8000
    }

    handle /stream/* {
        reverse_proxy backend:8000
    }

    handle /ws/* {
        reverse_proxy backend:8000
    }

    # Frontend static files and SPA fallback
    try_files {path} /index.html
    file_server
}
