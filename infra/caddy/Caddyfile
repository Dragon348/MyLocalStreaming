{
    auto_https off
    log {
        level INFO
        format json
    }
}

:80 {
    # Backend API - must be before generic handle
    handle /api/v1/* {
        reverse_proxy backend:8000
    }

    # Swagger Docs - must be before generic handle
    handle /docs {
        reverse_proxy backend:8000
    }

    handle /openapi.json {
        reverse_proxy backend:8000
    }

    # Music Streaming - must be before generic handle
    handle /stream/* {
        reverse_proxy backend:8000
    }

    # WebSockets
    handle /ws/* {
        reverse_proxy backend:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Frontend (Static files) - catch-all must be last
    handle /* {
        try_files {path} /index.html
        reverse_proxy frontend:80
    }
}